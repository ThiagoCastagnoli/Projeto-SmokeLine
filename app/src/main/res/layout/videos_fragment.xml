<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#0B0F14">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvTituloTopo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="SMOKE CABECINHA"
            android:textColor="@android:color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp" />

        <TextView
            android:id="@+id/tvSubtituloTopo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Base TR Cabecinha"
            android:textColor="#D8A24A"
            android:textSize="20sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardConteudo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="#111827"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvTituloCard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Smoke com CS2"
                    android:textColor="@android:color/white"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <FrameLayout
                    android:id="@+id/frameVideo"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    >


                         />



                    <VideoView
                        android:id="@+id/videoView2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvComoExecutar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Como executar"
                    android:textColor="@android:color/white"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="14dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🟩"
                        android:textSize="20sp"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:id="@+id/tvDescricao1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Posicione-se na superficie do video, proximo ao palacio e a sainda da caversa"
                        android:textColor="#C9D1D9"
                        android:textSize="18sp"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="➡️"
                        android:textSize="20sp"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:id="@+id/tvDescricao2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Com a mira alinhada, entre as 2 madeira do VIDEO, execute a como Jump Throw"
                        android:textColor="#C9D1D9"
                        android:textSize="18sp"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnVerPasso"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="Ver Passo a Passo"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="20sp"
                     />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>